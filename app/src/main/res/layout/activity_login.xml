<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/login"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="320dp"
        android:layout_height="550dp"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#EFFFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="580dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="25dp">

            <!-- Profile -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="114dp"
                android:layout_height="112dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_profile"
                android:padding="20dp"
                android:src="@drawable/user" />

            <!-- App Name -->
            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/agbalumo"
                android:text="Car2Pool"
                android:textColor="#00BCD4"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSlogan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="25dp"
                android:text="Ride Together • Save Together"
                android:textColor="#0D0000" />

            <!-- Username -->
            <EditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#5F5D5D"
                android:drawableStart="@android:drawable/ic_dialog_email"
                android:drawablePadding="10dp"
                android:hint="Email / Username"
                android:hintTextColor="#0D0000"
                android:inputType="textEmailAddress"
                android:textColor="#0D0000" />

            <!-- Password -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2C2A2A"
                android:drawableStart="@android:drawable/ic_lock_lock"
                android:drawablePadding="10dp"
                android:hint="Password"
                android:hintTextColor="#F1F1F1"
                android:inputType="textPassword"
                android:textColor="#FFFFFF" />

            <!-- Remember + Forgot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remember Me"
                    android:textColor="#0D0000" />

                <TextView
                    android:id="@+id/txtForgot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Forgot Password?"
                    android:textColor="#0D0000" />

            </LinearLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#49AD9A"
                android:onClick="loginClicked"
                android:text="LOGIN"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Register -->
            <TextView
                android:id="@+id/txtRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="25dp"
                android:text="Create New Account"
                android:textColor="#070101"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>